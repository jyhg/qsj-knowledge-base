# Optional root env file for local dev.
# Copy to `.env.local` and adjust as needed.

# Frontend -> backend
API_BASE_URL=http://localhost:3001/api/v1

# one service SQL execution
# Leave ONE_SERVICE_BASE_URL empty to use local mock execution in analysis flow.
ONE_SERVICE_BASE_URL=
ONE_SERVICE_SUBMIT_PATH=/internal/execution/sql-jobs
ONE_SERVICE_STATUS_PATH_TEMPLATE=/internal/execution/sql-jobs/{jobId}
ONE_SERVICE_TOKEN=
ONE_SERVICE_POLL_INTERVAL_MS=1000
ONE_SERVICE_POLL_MAX_ATTEMPTS=10

{
  "name": "qsj-knowledge-base",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @qsj/web run dev",
    "dev:api": "npm --workspace @qsj/api run start:dev",
    "build:web": "npm --workspace @qsj/web run build",
    "build:api": "npm --workspace @qsj/api run build",
    "typecheck:shared-types": "tsc -p packages/shared-types/tsconfig.json --noEmit",
    "test": "node --test tests/design-alignment.test.mjs tests/application-alignment.test.mjs tests/web-route-alignment.test.mjs tests/end-to-end-success-cases.test.mjs && npm run typecheck:shared-types",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
